# LangFuse self-host 环境变量模板。
# 用法：cp .env.example .env && 把所有 CHANGE_ME_* 替换成强随机串。
#
# 生成随机串（任选其一）：
#   openssl rand -hex 32
#   bun -e "console.log(crypto.randomUUID().replace(/-/g,'')+crypto.randomUUID().replace(/-/g,''))"
#   pwsh -c "[Convert]::ToHexString((1..32 | % { Get-Random -Max 256 }))"
#
# SALT / ENCRYPTION_KEY / NEXTAUTH_SECRET 改了会让历史数据无法解密，首部署定下就别动。

# —— 业务 Postgres ——
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# —— ClickHouse（trace/observation 主库）——
CLICKHOUSE_PASSWORD=CHANGE_ME_clickhouse_password

# —— MinIO（S3 兼容 blob 存储）——
MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_min_8_chars

# —— Redis（队列）——
REDIS_PASSWORD=CHANGE_ME_redis_password

# —— LangFuse 加密 / 签名密钥 ——
# SALT：API 凭证哈希盐，32+ 字符
SALT=CHANGE_ME_64_hex_chars_for_salt
# ENCRYPTION_KEY：AES-256 key，必须恰好 64 hex chars（= 32 bytes）
ENCRYPTION_KEY=CHANGE_ME_exactly_64_hex_chars_aes256_key_xxxxxxxxxxxxxxxxxxxxxx
# NEXTAUTH_SECRET：Web 会话签名密钥
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_random

# NEXTAUTH_URL：浏览器访问 LangFuse Web 的 URL。
# 本机调试用 http://localhost:3000；放到别的机器就改成对应 host。
NEXTAUTH_URL=http://localhost:3000

# —— 可选：首次启动自动建组织/项目/管理员（跳过 UI 初始化）——
# 留空 = 走手工 UI 注册。要用就全填。
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
# public/secret key 可先留空让 UI 创建；需要固定值时填 lf-pk-... / lf-sk-...
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=
