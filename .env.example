# 复制到 .env 后按需改值。.env 在 .gitignore 不会提交。
# 详细说明：docs/guides/using-cliproxy.md

# ── 走 CLIProxyAPI 代理（适用 GPT-5.x / Gemini / Claude Max 订阅）──
# 代理地址只到端口，不带 /v1（Anthropic SDK 自己加路径）
ANTHROPIC_BASE_URL=http://192.168.50.135:8317
ANTHROPIC_AUTH_TOKEN=sk-cliproxy

# Model 别名：三档都指到同一个后端模型
ANTHROPIC_DEFAULT_OPUS_MODEL=gpt-5.4
ANTHROPIC_DEFAULT_SONNET_MODEL=gpt-5.4
ANTHROPIC_DEFAULT_HAIKU_MODEL=gpt-5.4

# 可选：强制所有调用用同一 model（覆盖上面三个别名）
# ANTHROPIC_MODEL=gpt-5.4

# ── 直连 Anthropic 官方 API（不走代理）──
# 注释掉上面所有行，然后：
# ANTHROPIC_API_KEY=sk-ant-xxxxx
